#! rockbox/tagbrowser/2.0
# Custom database views with explicit content filtering
# Filters on comment tag containing "explicit=yes" or "EXPLICIT=no"

# ---- CLEAN LIBRARY (hides explicit tracks) ----
%menu_start "clean" "Clean Library"
"Artists" -> artist ? comment !~ "explicit=yes" -> album -> title
"Albums" -> album ? comment !~ "explicit=yes" -> title
"Genres" -> genre ? comment !~ "explicit=yes" -> artist -> album -> title
"All Tracks" -> title ? comment !~ "explicit=yes"
"Recently Added" -> album ? comment !~ "explicit=yes" & filename ^ "/" -> title = "created" > "4" & filename != ""

# ---- FULL LIBRARY (no filter) ----
%menu_start "full" "Full Library"
"Artists" -> artist -> album -> title
"Albums" -> album -> title
"Genres" -> genre -> artist -> album -> title
"All Tracks" -> title

# ---- EXPLICIT ONLY (shows only explicit tracks) ----
%menu_start "explicit" "Explicit Only"
"Artists" -> artist ? comment ~ "explicit=yes" -> album -> title
"Albums" -> album ? comment ~ "explicit=yes" -> title
"All Tracks" -> title ? comment ~ "explicit=yes"
